# ── Server ────────────────────────────────────────────────────────────
PORT=3000
# Client Bearer token for /v1/chat/completions and /v1/route.
# Leave unset with Cloudflare tunnel enabled to generate a fresh random key per server session.
# LEYLINE_CLIENT_API_KEY=leyline
# Set to false to skip client auth validation
# LEYLINE_CLIENT_AUTH_ENABLED=false
# Start a Cloudflare quick tunnel on boot (requires cloudflared in PATH)
LEYLINE_TUNNEL_ENABLED=true
# LEYLINE_TUNNEL_BINARY=cloudflared
# LEYLINE_TUNNEL_TIMEOUT_MS=45000
# Max JSON body size for /v1/* and dashboard API (default 100mb; Express default is 100kb)
# LEYLINE_BODY_LIMIT=100mb

# ── Cloud Provider API Keys ───────────────────────────────────────────
GEMINI_API_KEY=
HF_API_KEY=
OPENAI_API_KEY=
OPENAI_DEFAULT_MODEL=gpt-5.5
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_BASE_URL=https://your-resource.services.ai.azure.com/openai/v1
AZURE_OPENAI_DEFAULT_MODEL=gpt-5.5
# Legacy Azure deployment endpoint is also supported:
# AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com
# AZURE_OPENAI_DEPLOYMENT=your_deployment_name
AZURE_OPENAI_API_VERSION=2024-10-21
# You can also set/clear cloud provider API keys at runtime from /dashboard.
# Dashboard keys can be persisted in Apple Keychain, browser localStorage, or memory.
# .env keys are explicit startup config and take precedence over Keychain on startup.
LEYLINE_KEYCHAIN_ENABLED=true
LEYLINE_KEYCHAIN_SERVICE=@theaiinc/leyline

# ── Cloud Provider Quotas ─────────────────────────────────────────────
# Leyline-side RPM/RPD caps. Disabled by default — enable only for budget protection.
# LEYLINE_QUOTAS_ENABLED=true
GEMINI_QUOTA_RPM=10
GEMINI_QUOTA_RPD=1000
HF_QUOTA_RPM=100
HF_QUOTA_RPD=1000
OPENAI_QUOTA_RPM=60
OPENAI_QUOTA_RPD=1000
OPENROUTER_QUOTA_RPM=20
OPENROUTER_QUOTA_RPD=200
AZURE_OPENAI_QUOTA_RPM=60
AZURE_OPENAI_QUOTA_RPD=1000

# ── Local Model (LM Studio / OpenAI-compatible) ───────────────────────
LMSTUDIO_BASE_URL=http://host.docker.internal:1234/v1
LMSTUDIO_MODEL=

# ── LiteLLM Proxy (recommended Azure adapter for Cursor Agent) ─────────
# Run: npm run litellm:azure
# This starts LiteLLM on :4000 using AzureOpenAI key/runtime settings from env or Keychain.
LITELLM_ENABLED=true
LITELLM_BASE_URL=http://127.0.0.1:4000/v1
LITELLM_MODEL=gpt-5.5
LITELLM_API_KEY=not-needed

# ── Router / Classifier Model ─────────────────────────────────────────
# The lightweight model used to classify requests (complexity/domain/reasoning).
# Example: arch-router-1.5b.gguf
LEYLINE_ROUTER_MODEL=
LEYLINE_ROUTER_MAX_TOKENS=64
LEYLINE_ROUTER_TEMPERATURE=0
# Base URL for the LLM endpoint that hosts the router model
LEYLINE_OPENAI_BASE_URL=http://localhost:1234/v1

# Disable dynamic routing/failover and send every chat completion to one model.
# Recommended for Cursor + Azure OpenAI:
LEYLINE_ROUTER_ENABLED=false
LEYLINE_FIXED_PROVIDER=LiteLLM
LEYLINE_FIXED_MODEL=gpt-5.5
# Set LEYLINE_ROUTER_ENABLED=true to re-enable multi-provider failover.
# LEYLINE_FIXED_PROVIDER=
# LEYLINE_FIXED_MODEL=

# Local Ollama is opt-in — enable only when you want Leyline to fail over to localhost:11434.
# OLLAMA_ENABLED=true
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_DEFAULT_MODEL=llama2

# ── Tier → Model Resolution ───────────────────────────────────────────
# Maps tier labels to actual model names.
# These are the model names used by the code policy for route resolution.
LEYLINE_MODEL_2B=
LEYLINE_MODEL_4B=
LEYLINE_MODEL_12B=

# ── Custom Model Variants Registry (JSON) ─────────────────────────────
# If set, leyline uses these variants INSTEAD of the built-in defaults.
# This lets consumers define their own model catalog (names, providers,
# capabilities, billing, etc.) without modifying leyline source.
#
# Format: JSON array of ModelVariant objects.
# Example:
# LEYLINE_CUSTOM_VARIANTS=[{"id":"google/gemma-4-12b","name":"Gemma 4 12B","family":"gemma-4","provider":"openai","source":"lmstudio","parameter_size_b":12,"quantization":"Q4_K_M","context_length":262144,"capabilities":{"tools":true,"thinking":true,"vision":true,"code":true,"embedding":false},"billing_class":"free_local","resource_class":"standard"}]
LEYLINE_CUSTOM_VARIANTS=

# ── Prompt Compression (@theaiinc/headroom-ai, optional) ────────────────
# Fork of chopratejas/headroom, library-only (no proxy).
# Install: pip install headroom-ai
#
# Uses the `headroom-compress` CLI or falls back to `python3 -m headroom.json_cli`.
# Passes messages as JSON on stdin, receives compressed messages as JSON on stdout.
LEYLINE_COMPRESSION_ENABLED=false
LEYLINE_COMPRESSION_MODEL=
LEYLINE_COMPRESSION_TOKEN_BUDGET=
